# Cloudflare Turnstile
# Create a site at https://dash.cloudflare.com/?to=/:account/turnstile
# Use "Invisible" widget type
VITE_TURNSTILE_SITE_KEY=your_site_key_here

# Server-side secret — add to .dev.vars for local dev:
# TURNSTILE_SECRET=your_turnstile_secret_key_here
# Deploy to production via:
# npx wrangler secret put TURNSTILE_SECRET
